# ============================================================
#  Source Code Analysis using GenAI — Environment Variables
# ============================================================
#  Copy this file to .env and fill in your values.
#  Only ONE LLM provider section is required.
# ============================================================

# ────────────────────────────────────────────────────────────
# LLM PROVIDER — choose one: groq | openai | ollama
# ────────────────────────────────────────────────────────────
LLM_PROVIDER=groq

# ── Groq (FREE tier — recommended) ─────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
# Available free models: llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it

# ── OpenAI (optional, costs money) ─────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ── Ollama (fully local, 100% free, no API key) ─────────────
# Install: https://ollama.com  then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ────────────────────────────────────────────────────────────
# EMBEDDING PROVIDER — choose one: fastembed | openai | voyage
# ────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=fastembed
# fastembed uses BAAI/bge-small-en-v1.5 locally — no key needed

# ── Voyage AI (best for code — free tier 50M tokens/month) ──
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_MODEL=voyage-code-2

# ────────────────────────────────────────────────────────────
# QDRANT VECTOR STORE
# ────────────────────────────────────────────────────────────
# Use ":memory:" for local in-memory (no Docker needed)
# Use "http://localhost:6333" if running Qdrant via Docker
QDRANT_URL=:memory:
QDRANT_API_KEY=                    # Leave empty for local
QDRANT_COLLECTION=code_rag

# ────────────────────────────────────────────────────────────
# RETRIEVAL SETTINGS
# ────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20          # candidates fetched from Qdrant
RERANK_TOP_N=5              # after cross-encoder reranking
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# ────────────────────────────────────────────────────────────
# OBSERVABILITY (optional)
# ────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=code-rag

# ────────────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8080
APP_DEBUG=false
REPO_CLONE_DIR=./repo
ALLOWED_HOSTS=github.com,gitlab.com,bitbucket.org
# CORS allowed origins (comma-separated). Use "*" for open dev access.
# In production, restrict this: CORS_ORIGINS=https://yourapp.com
CORS_ORIGINS=*
