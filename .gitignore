# ── Security & Secret Exclusions (Crucial for production security) ────────────
# Ignore API keys, passwords, and service account keys
*secret*
*credential*
*.pem
*.key
*.crt
*.p12
*.pfx
*.der
*.csr
*.cer
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.pub
/gcp-key.json
/aws-credentials

# ── Ingested Source Code & Local Vector Storage ──────────────────────────────
# Cloned source repos (to prevent accidental leaks of external codebases)
repo/
/repo
**/repo/
research/test_repo/*
research/data/*

# Vector DB storage & local metadata
db/
qdrant_data/
qdrant_storage/
/qdrant_data/
/qdrant_storage/

